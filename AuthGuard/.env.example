# Server
PORT=3000

# Redis
REDIS_URL=redis://redis:6379

# Auth (Keycloak JWKS endpoint)
JWKS_URL=http://keycloak:8080/realms/master/protocol/openid-connect/certs

# Target service (proxy)
TARGET_SERVICE=http://service:4000

# Rate limiting
RATE_LIMIT=100
WINDOW_SECONDS=60

# Secrets
GOOGLE_CLIENT_ID="your-client-id-google.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret-google"

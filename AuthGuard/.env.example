# ══════════════════════════════════════════════════════════════════════
#                AUTHGUARD STACK - ENVIRONMENT CONFIGURATION
# ══════════════════════════════════════════════════════════════════════

# --- CORE SETTINGS ---
ADMIN_PASSWORD=admin

# --- KEYCLOAK CLIENT CREDENTIALS ---
KEYCLOAK_CLIENT_SECRET=qiQ8IospPnLNfL2y5x1hfs2Bpf10D0ky

# --- GOOGLE CLOUD OAUTH 2.0 (Identity Provider) ---
# Create these at: https://console.cloud.google.com/
# Redirect URI must be: http://localhost:8080/auth/realms/authguard/broker/google/endpoint
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ══════════════════════════════════════════════════════════════════════
# WARNING: NEVER commit your actual .env file with real secrets!
# Use this .env.example as a template for your local .env

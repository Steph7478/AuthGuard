{
    "clientId": "authguard-service",
    "name": "AuthGuard Principal",
    "enabled": true,
    "protocol": "openid-connect",
    "publicClient": false,
    "bearerOnly": false,
    "serviceAccountsEnabled": true,
    "standardFlowEnabled": true,
    "directAccessGrantsEnabled": true,
    "webOrigins": [
        "*"
    ],
    "redirectUris": [
        "http://localhost:3000/*"
    ]
}
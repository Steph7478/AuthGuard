{
  "realm": "authguard",
  "displayName": "AuthGuard Realm",
  "enabled": true,
  "sslRequired": "none",
  "bruteForceProtected": true,
  "failureFactor": 5,
  "maxFailureWaitSeconds": 900,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "requiredActions": [],
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": true,
      "addReadTokenRoleOnCreate": true,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "${GOOGLE_CLIENT_ID}",
        "clientSecret": "${GOOGLE_CLIENT_SECRET}",
        "defaultScope": "openid profile email",
        "syncMode": "IMPORT",
        "useJwksUrl": "true",
        "redirectUri": "http://localhost:8080/realms/authguard/broker/google/endpoint",
        "authorizationUrl": "https://accounts.google.com/o/oauth2/v2/auth",
        "tokenUrl": "https://oauth2.googleapis.com/token",
        "userInfoUrl": "https://www.googleapis.com/oauth2/v3/userinfo",
        "jwksUrl": "https://www.googleapis.com/oauth2/v3/certs",
        "validateSignature": "true",
        "pkceEnabled": "false",
        "disableUserInfoService": "false"
      }
    }
  ],
  "identityProviderMappers": [
    {
      "name": "username-google",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-username-idp-mapper",
      "config": {
        "claim": "email",
        "template": "${CLAIM.email}"
      }
    },
    {
      "name": "first-name",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "claim": "given_name",
        "userAttribute": "firstName"
      }
    },
    {
      "name": "last-name",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "claim": "family_name",
        "userAttribute": "lastName"
      }
    },
    {
      "name": "email",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "claim": "email",
        "userAttribute": "email"
      }
    },
    {
      "name": "profile-picture",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "claim": "picture",
        "userAttribute": "pictureUrl"
      }
    },
    {
      "name": "google-subject",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "claim": "sub",
        "userAttribute": "googleId"
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Admin Total"
      },
      {
        "name": "financeiro",
        "description": "Acesso Financeiro"
      },
      {
        "name": "rh",
        "description": "Acesso RH"
      }
    ]
  },
  "groups": [
    {
      "name": "TI",
      "path": "/TI",
      "subGroups": [
        {
          "name": "Desenvolvimento",
          "path": "/TI/Desenvolvimento",
          "attributes": {
            "costCenter": [
              "DEV-001"
            ]
          }
        },
        {
          "name": "Infraestrutura",
          "path": "/TI/Infraestrutura",
          "attributes": {
            "costCenter": [
              "INFRA-002"
            ]
          }
        }
      ]
    },
    {
      "name": "RH",
      "path": "/RH",
      "attributes": {
        "costCenter": [
          "RH-003"
        ]
      }
    },
    {
      "name": "Financeiro",
      "path": "/Financeiro",
      "attributes": {
        "costCenter": [
          "FIN-004"
        ]
      }
    }
  ],
  "clients": [
    {
      "clientId": "authguard-service",
      "name": "AuthGuard Backend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "${KEYCLOAK_CLIENT_SECRET}",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "redirectUris": [],
      "webOrigins": [],
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "full.path": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "costCenter",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "costCenter",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "costCenter",
            "jsonType.label": "String",
            "multivalued": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "authguard-service",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "${ADMIN_PASSWORD}",
          "temporary": false
        }
      ],
      "groups": [
        "/TI/Infraestrutura"
      ],
      "realmRoles": [
        "admin"
      ]
    }
  ]
}
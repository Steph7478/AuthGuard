{
  "realm": "authguard",
  "displayName": "AuthGuard Realm",
  "enabled": true,
  "sslRequired": "external",
  "bruteForceProtected": true,
  "failureFactor": 5,
  "maxFailureWaitSeconds": 900,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "requiredActions": [],
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Admin Total"
      },
      {
        "name": "financeiro",
        "description": "Acesso Financeiro"
      },
      {
        "name": "rh",
        "description": "Acesso RH"
      }
    ]
  },
  "groups": [
    {
      "name": "TI",
      "path": "/TI",
      "subGroups": [
        {
          "name": "Desenvolvimento",
          "path": "/TI/Desenvolvimento",
          "attributes": {
            "costCenter": [
              "DEV-001"
            ]
          }
        },
        {
          "name": "Infraestrutura",
          "path": "/TI/Infraestrutura",
          "attributes": {
            "costCenter": [
              "INFRA-002"
            ]
          }
        }
      ]
    },
    {
      "name": "RH",
      "path": "/RH",
      "attributes": {
        "costCenter": [
          "RH-003"
        ]
      }
    },
    {
      "name": "Financeiro",
      "path": "/Financeiro",
      "attributes": {
        "costCenter": [
          "FIN-004"
        ]
      }
    }
  ],
  "clients": [
    {
      "clientId": "authguard-service",
      "name": "AuthGuard Backend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "qiQ8IospPnLNfL2y5x1hfs2Bpf10D0ky",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "redirectUris": [],
      "webOrigins": [],
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "full.path": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "costCenter",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "costCenter",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "costCenter",
            "jsonType.label": "String",
            "multivalued": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "groups": [
        "/TI/Infraestrutura"
      ],
      "realmRoles": [
        "admin"
      ]
    }
  ]
}